# Python bytecode and caches
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Virtual environments
.venv/
venv/
env/

# Jupyter and editor state
.ipynb_checkpoints/
.vscode/
.idea/

# OS metadata
.DS_Store
Thumbs.db

# Logs
logs/*
!logs/.gitkeep
*.log

# Data artifacts
data/raw/*
!data/raw/.gitkeep
data/processed/*
!data/processed/.gitkeep
data/results/*
!data/results/.gitkeep

# Training and experiment outputs
runs/*
!runs/.gitkeep
checkpoints/
models/
*.pt
*.pth
*.ckpt
*.zip
events.out.tfevents.*

# Generated binary/scientific artifacts
*.npy
*.npz
*.pkl
*.pickle

# Keep explicit placeholders when needed
!.gitkeep
